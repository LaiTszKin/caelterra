# ============================================================
# Apollo Toolkit - Spec Test Execution Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
#   cp .env.example .env
# The .env file is git-ignored and will never be committed.

# --- Execution Model (the agent under test) ---
# Base URL for the execution model API (OpenAI-compatible endpoint)
EXEC_BASE_URL=https://api.deepseek.com
# Model name to use for test execution
EXEC_MODEL=deepseek-chat
# API key for the execution model
EXEC_API_KEY=sk-your-exec-api-key-here
# Reasoning effort parameter (e.g., low, medium, high)
EXEC_REASONING_EFFORT=medium

# --- Judge Model (LLM-as-Judge scorer) ---
# Base URL for the judge model API (OpenAI-compatible endpoint)
JUDGE_BASE_URL=https://api.deepseek.com
# Model name to use for scoring test results
JUDGE_MODEL=deepseek-chat
# API key for the judge model
JUDGE_API_KEY=sk-your-judge-api-key-here
# Reasoning effort for judge model
JUDGE_REASONING_EFFORT=medium

# --- Concurrency and Timeout ---
# Maximum number of test executions running concurrently (default: 10)
EXEC_CONCURRENCY=10
# Maximum number of scoring operations running concurrently (default: 5)
JUDGE_CONCURRENCY=5
# Timeout in seconds for each test execution (default: 600)
EXEC_TIMEOUT=600
