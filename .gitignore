# Tooling / OS
.DS_Store
**/.DS_Store

# Secrets
**/.env

# Claude Code session artifacts (local only)
.claude/

# TypeScript build output
dist/
*.tsbuildinfo

# Apollo Toolkit architecture diff viewer default output (local only)
.apollo-toolkit/

# Test execution artifacts (local only)
assets/spec/*/test_*/
results/

# Coverage reports (generated from c8 / --experimental-test-coverage)
coverage/

# ESLint cache (auto-generated)
.eslintcache

# Node — after clone or `pnpm install`, dependencies live here locally only.
# Root pnpm-lock.yaml MUST stay committed so `pnpm install --frozen-lockfile`
# resolves the same tree across environments.
node_modules/
assets/spec/rg*-*/
