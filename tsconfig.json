{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["bin/**/*.ts"],
  "exclude": ["node_modules", "dist", ".claude", "resources"],
  "references": [
    { "path": "packages/tui" },
    { "path": "packages/tool-registry" },
    { "path": "packages/tool-utils" },
    { "path": "packages/cli" },
    { "path": "packages/tools/architecture" },
    { "path": "packages/tools/codegraph" },
    { "path": "packages/tools/eval" },
    { "path": "packages/tools/create-review-report" },
    { "path": "packages/tools/create-specs" },
    { "path": "packages/tools/docs-to-voice" },
    { "path": "packages/tools/enforce-video-aspect-ratio" },
    { "path": "packages/tools/extract-conversations" },
    { "path": "packages/tools/extract-pdf-text" },
    { "path": "packages/tools/filter-logs" },
    { "path": "packages/tools/find-github-issues" },
    { "path": "packages/tools/generate-storyboard-images" },
    { "path": "packages/tools/open-github-issue" },
    { "path": "packages/tools/read-github-issue" },
    { "path": "packages/tools/render-error-book" },
    { "path": "packages/tools/render-katex" },
    { "path": "packages/tools/review-threads" },
    { "path": "packages/tools/search-logs" },
    { "path": "packages/tools/sync-memory-index" },
    { "path": "packages/tools/validate-openai-agent-config" },
    { "path": "packages/tools/validate-skill-frontmatter" }
  ]
}
