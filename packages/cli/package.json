{
  "name": "@laitszkin/cli",
  "version": "5.0.0",
  "description": "Apollo Toolkit — CLI command management (install, uninstall, tool routing)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "test": "node --test dist/"
  },
  "dependencies": {
    "@laitszkin/tui": "workspace:*",
    "@laitszkin/tool-registry": "workspace:*",
    "@laitszkin/tool-utils": "workspace:*",
    "@laitszkin/tool-validate-skill-frontmatter": "workspace:*",
    "@laitszkin/tool-validate-openai-agent-config": "workspace:*",
    "@laitszkin/tool-open-github-issue": "workspace:*",
    "@laitszkin/tool-find-github-issues": "workspace:*",
    "@laitszkin/tool-read-github-issue": "workspace:*",
    "@laitszkin/tool-review-threads": "workspace:*",
    "@laitszkin/tool-architecture": "workspace:*",
    "@laitszkin/tool-codegraph": "workspace:*",
    "@laitszkin/tool-create-specs": "workspace:*",
    "@laitszkin/tool-create-review-report": "workspace:*",
    "@laitszkin/tool-eval": "workspace:*",
    "pacote": "^22.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "dist"
  ]
}
