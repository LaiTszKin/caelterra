{
  "name": "@laitszkin/cli",
  "version": "5.0.0",
  "description": "Apollo Toolkit \u2014 CLI command management (install, uninstall, tool routing)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
