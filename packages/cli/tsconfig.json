{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "strict": true,
    "composite": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["**/*.ts"],
  "exclude": ["dist", "node_modules"],
  "references": [
    { "path": "../tui" },
    { "path": "../tool-registry" },
    { "path": "../tools/architecture" },
    { "path": "../tools/create-review-report" },
    { "path": "../tools/create-specs" },
    { "path": "../tools/docs-to-voice" },
    { "path": "../tools/enforce-video-aspect-ratio" },
    { "path": "../tools/extract-conversations" },
    { "path": "../tools/extract-pdf-text" },
    { "path": "../tools/filter-logs" },
    { "path": "../tools/find-github-issues" },
    { "path": "../tools/generate-storyboard-images" },
    { "path": "../tools/open-github-issue" },
    { "path": "../tools/read-github-issue" },
    { "path": "../tools/render-error-book" },
    { "path": "../tools/render-katex" },
    { "path": "../tools/review-threads" },
    { "path": "../tools/search-logs" },
    { "path": "../tools/sync-memory-index" },
    { "path": "../tools/validate-openai-agent-config" },
    { "path": "../tools/validate-skill-frontmatter" }
  ]
}
