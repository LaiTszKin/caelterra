{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noPropertyAccessFromIndexSignature": true,
    "composite": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["**/*.ts"],
  "exclude": ["dist", "node_modules"],
  "references": [
    { "path": "../tui" },
    { "path": "../tool-registry" },
    { "path": "../tools/architecture" },
    { "path": "../tools/create-review-report" },
    { "path": "../tools/create-specs" },
    { "path": "../tools/find-github-issues" },
    { "path": "../tools/open-github-issue" },
    { "path": "../tools/read-github-issue" },
    { "path": "../tools/review-threads" },
    { "path": "../tools/validate-openai-agent-config" },
    { "path": "../tools/validate-skill-frontmatter" }
  ]
}
