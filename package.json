{
  "name": "@laitszkin/apollo-toolkit",
  "version": "5.2.2",
  "description": "Apollo Toolkit npm installer for managed skill copying across Codex, OpenClaw, and Trae.",
  "license": "MIT",
  "author": "LaiTszKin",
  "homepage": "https://github.com/LaiTszKin/apollo-toolkit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LaiTszKin/apollo-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/LaiTszKin/apollo-toolkit/issues"
  },
  "type": "module",
  "workspaces": [
    "packages/*",
    "packages/tools/*"
  ],
  "main": "dist/bin/apollo-toolkit.js",
  "bin": {
    "apollo-toolkit": "dist/bin/apollo-toolkit.js",
    "apltk": "dist/bin/apollo-toolkit.js"
  },
  "scripts": {
    "build": "tsc --build",
    "postbuild": "node scripts/rewrite-imports.mjs",
    "prepublishOnly": "npm run build",
    "watch": "tsc --build --watch",
    "test": "scripts/test.sh",
    "test:coverage": "COVERAGE=true npm test",
    "test:ts": "node --test dist/test/"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "keywords": [
    "apollo-toolkit",
    "codex",
    "skills",
    "openclaw",
    "trae"
  ],
  "dependencies": {
    "@inquirer/prompts": "^8.0.0",
    "chalk": "^5.0.0",
    "elkjs": "^0.11.1",
    "js-yaml": "^4.1.1"
  },
  "optionalDependencies": {
    "@colbymchenry/codegraph": "^0.9.9"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
